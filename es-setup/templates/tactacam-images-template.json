{
  "index_patterns": ["tactacam-images*"],
  "template": {
    "mappings": {
      "properties": {
        "@timestamp":   { "type": "date" },
        "ingest_ts":    { "type": "date" },
        "camera_id":    { "type": "keyword" },
        "camera_name":  { "type": "keyword" },
        "property_id":  { "type": "keyword" },
        "filename":     { "type": "keyword" },
        "s3_key":       { "type": "keyword" },
        "location":     { "type": "geo_point" },
        "has_headshot": { "type": "boolean" },
        "signal":       { "type": "keyword" },
        "battery":      { "type": "keyword" },
        "weather": {
          "properties": {
            "temperature":       { "type": "float" },
            "temp_max_12h":      { "type": "float" },
            "temp_min_12h":      { "type": "float" },
            "wind_speed":        { "type": "float" },
            "wind_deg":          { "type": "float" },
            "wind_cardinal":     { "type": "keyword" },
            "wind_gust":         { "type": "float" },
            "pressure_hpa":      { "type": "float" },
            "pressure_tendency": { "type": "keyword" },
            "moon_phase":        { "type": "keyword" },
            "sun_phase":         { "type": "keyword" },
            "label":             { "type": "keyword" },
            "temp_departure_24h":{ "type": "float" }
          }
        },
        "ai_analyzed":          { "type": "boolean" },
        "ai_analyzed_at":       { "type": "date" },
        "ai_has_animal":        { "type": "boolean" },
        "ai_species":           { "type": "keyword" },
        "ai_sex":               { "type": "keyword" },
        "ai_age_class":         { "type": "keyword" },
        "ai_antlers":           { "type": "text" },
        "ai_labels":            { "type": "keyword" },
        "ai_confidence":        { "type": "float" },
        "ai_notes":             { "type": "text" },
        "ai_error":             { "type": "keyword" },
        "animal_id":            { "type": "keyword" },
        "animal_name":          { "type": "keyword" },

        "human_labeled":        { "type": "boolean" },
        "human_species":        { "type": "keyword" },
        "human_sex":            { "type": "keyword" },
        "human_age_class":      { "type": "keyword" },
        "human_antlers":        { "type": "text" },
        "human_notes":          { "type": "text" },

        "ai_notes_semantic": {
          "type": "semantic_text",
          "inference_id": "ridgeline-elser"
        },
        "ai_antlers_semantic": {
          "type": "semantic_text",
          "inference_id": "ridgeline-elser"
        },

        "embedding": {
          "type": "dense_vector",
          "dims": 512,
          "index": true,
          "similarity": "cosine"
        }
      }
    }
  },
  "_meta": { "description": "Tactacam trail camera images with weather, GPS, AI labels, ELSER semantic search, and CLIP embeddings" }
}
